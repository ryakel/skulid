# --- Public reachability ---------------------------------------------------
# The public HTTPS URL Google will redirect to and use to deliver push
# notifications. Use a tunnel (cloudflared, Tailscale Funnel) or a real
# reverse proxy. Required.
EXTERNAL_URL=https://skulid.example.com

# Optional: host port to publish the container on (default 8567).
HOST_PORT=8567

# --- Container image -------------------------------------------------------
# docker-compose pulls this by default. Point SKULID_IMAGE at your internal
# registry to deploy from there instead. SKULID_TAG pins a release;
# defaults to :latest.
SKULID_IMAGE=ghcr.io/ryakel/skulid
SKULID_TAG=latest

# --- Google OAuth ----------------------------------------------------------
# Create a Web Application OAuth client at https://console.cloud.google.com/
# and add EXTERNAL_URL/auth/google/callback to the authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Secrets ---------------------------------------------------------------
# A long random string used to sign session cookies (>= 32 bytes recommended).
#   openssl rand -base64 48
SESSION_SECRET=

# Base64 of 32 random bytes — used as the AES-256-GCM key that encrypts
# every stored OAuth refresh/access token. If you lose this, you must
# re-connect every Google account.
#   openssl rand -base64 32
ENCRYPTION_KEY=

# --- AI assistant (optional) -----------------------------------------------
# Setting ANTHROPIC_API_KEY enables the in-app Claude-powered assistant
# at /assistant. Conversations live in Postgres for 30 days. Every write
# the assistant proposes requires you to click Apply before it hits Google.
# Leave empty to disable the feature entirely.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- Dev auth bypass (LOCAL DEV ONLY) -------------------------------------
# Set SKULID_DEV_AUTH_BYPASS=1 to register GET /dev/login. Hitting that route
# claims TOFU as SKULID_DEV_USER_EMAIL (default dev@local) and issues a real
# session cookie — every owner-protected page works without doing a real
# Google OAuth round-trip. The login page shows a "Skip OAuth →" link, every
# rendered page carries a yellow DEV AUTH BYPASS banner, and the daemon
# logs a WARN at startup. NEVER set this in production.
SKULID_DEV_AUTH_BYPASS=
SKULID_DEV_USER_EMAIL=dev@local

# --- Postgres --------------------------------------------------------------
POSTGRES_USER=skulid
POSTGRES_PASSWORD=changeme
POSTGRES_DB=skulid
